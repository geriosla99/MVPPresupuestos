# Conexión MySQL/MariaDB
# Formato: mysql+pymysql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=mysql+pymysql://root:tupassword@localhost:3306/tupresupuesto

# JWT — cambia esto por una cadena aleatoria larga en producción
# Puedes generarla con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esto-por-una-cadena-secreta-muy-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes permitidos (CORS) — separados por coma
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
