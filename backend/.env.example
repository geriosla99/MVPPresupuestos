# ─── Firebase / Firestore ───
# Project ID de tu proyecto Firebase (lo ves en la URL de la consola)
FIREBASE_PROJECT_ID=tupresupuesto-901b0

# Ruta al JSON de credenciales de servicio:
# 1) En la consola de Firebase → Configuración del proyecto → Cuentas de servicio
# 2) Clic en "Generar nueva clave privada" → descarga un .json
# 3) Guárdalo dentro de backend/ y pon aquí su ruta (relativa o absoluta)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ─── JWT ───
# Cadena secreta larga y aleatoria. Generarla con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esto-por-una-cadena-secreta-muy-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Firebase credentials para serverless (Vercel, Cloud Run) ───
# Alternativa al archivo: pegar aquí el JSON completo en una sola línea.
# Si está definido, tiene prioridad sobre FIREBASE_CREDENTIALS_PATH.
FIREBASE_CREDENTIALS_JSON=

# ─── CORS ───
# Local + producción (frontend en Vercel). Separar por coma sin espacios.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://mvp-presupuestos-8azi.vercel.app
